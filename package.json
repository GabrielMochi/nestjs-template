{
  "name": "sherlock-web-server",
  "version": "0.1.0",
  "description": "NestJS SSE server for Sherlock username searches.",
  "license": "UNLICENSED",
  "author": "GabrielMochi",
  "scripts": {
    "build": "nest build",
    "format": "oxfmt --write package.json .oxlintrc.json .oxfmtrc.json \"src/**/*.ts\" \"test/**/*.ts\" \"*.mjs\"",
    "format:check": "oxfmt --check package.json .oxlintrc.json .oxfmtrc.json \"src/**/*.ts\" \"test/**/*.ts\" \"*.mjs\"",
    "lint": "oxlint src test vitest.config.mjs vitest.e2e.config.mjs --fix --type-aware --node-plugin --vitest-plugin --promise-plugin",
    "lint:check": "oxlint src test vitest.config.mjs vitest.e2e.config.mjs --type-aware --node-plugin --vitest-plugin --promise-plugin",
    "prepare": "lefthook install",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "vitest run --config ./vitest.config.mjs",
    "test:watch": "vitest --config ./vitest.config.mjs",
    "test:cov": "vitest run --coverage --config ./vitest.config.mjs",
    "test:debug": "vitest --inspect-brk --run --config ./vitest.config.mjs",
    "test:e2e": "vitest run --config ./vitest.e2e.config.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "helmet": "^8.2.0",
    "js-yaml": "^4.2.0",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "webpack": "^5.107.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@oxc-project/runtime": "^0.137.0",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "lefthook": "^2.1.9",
    "oxc-transform": "^0.137.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
