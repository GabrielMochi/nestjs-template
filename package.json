{
  "name": "nestjs-template",
  "version": "0.1.0",
  "description": "A template project for NestJS applications, providing a pre-configured setup with essential dependencies and scripts for building, testing, and running a NestJS application.",
  "author": "GabrielMochi",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run --config ./vitest.config.mjs",
    "test:watch": "vitest --config ./vitest.config.mjs",
    "test:cov": "vitest run --coverage --config ./vitest.config.mjs",
    "test:debug": "vitest --inspect-brk --run --config ./vitest.config.mjs",
    "test:e2e": "vitest run --config ./vitest.e2e.config.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "helmet": "^8.2.0",
    "js-yaml": "^4.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "webpack": "^5.107.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@oxc-project/runtime": "^0.137.0",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "oxc-transform": "^0.137.0",
    "prettier": "^3.8.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  }
}
